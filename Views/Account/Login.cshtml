@model Diplom.ViewModels.LoginViewModel

@{
    Layout = null;
    int attempts = TempData.Peek("FailedAttempts") as int? ?? 0;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход в систему — Счастье есть</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --rose:      #e8a0b4;
            --plum:      #7c3f7e;
            --cream:     #fff8f4;
            --dark:      #2b1a2e;
            --muted:     #9b7fa0;
            --error:     #c0392b;
            --card-bg:   rgba(255, 248, 244, 0.72);
        }

        /* ── BACKGROUND ── */
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
            background-color: #1e0f22;
            overflow: hidden;
            position: relative;
        }

        /* Animated blobs */
        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.55;
            animation: drift 12s ease-in-out infinite alternate;
        }
        .blob-1 { width: 520px; height: 520px; background: #7c3f7e; top: -140px; left: -100px; animation-delay: 0s; }
        .blob-2 { width: 400px; height: 400px; background: #e8a0b4; bottom: -120px; right: -80px; animation-delay: -4s; }
        .blob-3 { width: 300px; height: 300px; background: #4a1a55; top: 40%; left: 55%; animation-delay: -8s; }

        @@keyframes drift {
            0%   { transform: translate(0, 0) scale(1); }
            100% { transform: translate(30px, 40px) scale(1.08); }
        }

        /* Noise overlay */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            opacity: 0.4;
            z-index: 0;
        }

        /* ── CARD ── */
        .login-wrap {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 440px;
            padding: 16px;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(24px) saturate(1.6);
            -webkit-backdrop-filter: blur(24px) saturate(1.6);
            border: 1px solid rgba(255,255,255,0.45);
            border-radius: 24px;
            padding: 48px 44px 44px;
            box-shadow:
                0 2px 0 rgba(255,255,255,0.6) inset,
                0 32px 64px rgba(0,0,0,0.45);
            animation: cardIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @@keyframes cardIn {
            from { opacity: 0; transform: translateY(28px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)    scale(1); }
        }

        /* ── HEADER ── */
        .brand {
            text-align: center;
            margin-bottom: 38px;
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, #e8a0b4, #7c3f7e);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #fff;
            margin-bottom: 16px;
            box-shadow: 0 8px 24px rgba(124,63,126,0.4);
        }

        .brand h1 {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 26px;
            font-weight: 600;
            color: var(--dark);
            letter-spacing: -0.3px;
            line-height: 1.2;
        }

        .brand p {
            font-size: 13.5px;
            color: var(--muted);
            margin-top: 6px;
            font-weight: 300;
        }

        /* ── FIELDS ── */
        .field {
            margin-bottom: 22px;
        }

        .field label {
            display: block;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .field-inner {
            position: relative;
        }

        .field-inner i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 16px;
            pointer-events: none;
            transition: color 0.2s;
        }

        .field-inner input {
            width: 100%;
            background: rgba(255,255,255,0.6);
            border: 1.5px solid rgba(124,63,126,0.15);
            border-radius: 12px;
            padding: 13px 14px 13px 42px;
            font-size: 15px;
            font-family: 'DM Sans', sans-serif;
            color: var(--dark);
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
        }

        .field-inner input::placeholder { color: #c4aec8; }

        .field-inner input:focus {
            border-color: var(--plum);
            background: rgba(255,255,255,0.88);
            box-shadow: 0 0 0 4px rgba(124,63,126,0.12);
        }

        .field-inner input:focus + i,
        .field-inner:focus-within i { color: var(--plum); }

        /* reorder so icon sits behind input visually but above in DOM */
        .field-inner i { z-index: 1; }
        .field-inner input { position: relative; z-index: 2; background-clip: padding-box; }

        /* ── FORGOT ── */
        .forgot-row {
            text-align: right;
            margin-top: -10px;
            margin-bottom: 18px;
        }

        .forgot-row a {
            font-size: 12.5px;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-row a:hover { color: var(--plum); }

        /* ── BUTTON ── */
        .btn-login {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #c868d4 0%, #7c3f7e 100%);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 500;
            letter-spacing: 0.5px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 6px 20px rgba(124,63,126,0.45);
            margin-top: 6px;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 60%);
        }

        .btn-login:hover  { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(124,63,126,0.55); }
        .btn-login:active { transform: translateY(0);    box-shadow: 0 4px 14px rgba(124,63,126,0.35); }

        /* ── ERROR ── */
        .error-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(192,57,43,0.08);
            border: 1px solid rgba(192,57,43,0.2);
            border-radius: 10px;
            padding: 10px 14px;
            margin-top: 18px;
            color: var(--error);
            font-size: 13px;
            font-weight: 500;
            animation: shake 0.4s ease;
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-5px); }
            60%       { transform: translateX(5px); }
            80%       { transform: translateX(-3px); }
        }

        /* ── DIVIDER & FOOTER ── */
        .card-footer-note {
            text-align: center;
            margin-top: 28px;
            font-size: 12px;
            color: var(--muted);
        }

        .dots {
            display: flex;
            justify-content: center;
            gap: 6px;
            margin-top: 22px;
        }

        .dots span {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--rose);
            opacity: 0.4;
        }
        .dots span:nth-child(2) { opacity: 0.65; background: var(--plum); }
        .dots span:nth-child(3) { opacity: 0.25; }
    </style>
</head>
<body>

    <!-- Animated background blobs -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="login-wrap">
        <div class="login-card">

            <!-- Brand header -->
            <div class="brand">
                <div class="brand-icon">
                    <i class="bi bi-cake2"></i>
                </div>
                <h1>Счастье есть</h1>
                <p>Система управления кондитерской</p>
            </div>

            <form asp-action="Login" method="post" autocomplete="off">

                <!-- Login field -->
                <div class="field">
                    <label asp-for="Login">Логин</label>
                    <div class="field-inner">
                        <input asp-for="Login"
                               type="text"
                               placeholder="Введите логин"
                               autocomplete="username" />
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>

                <!-- Password field -->
                <div class="field">
                    <label asp-for="Password">Пароль</label>
                    <div class="field-inner">
                        <input asp-for="Password"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                        <i class="bi bi-lock-fill"></i>
                    </div>
                </div>

                <!-- Forgot password (appears after 3 failed attempts) -->
                @if (attempts >= 3)
                {
                    <div class="forgot-row">
                        <a asp-action="ForgotPassword">Забыли пароль?</a>
                    </div>
                }

                <!-- Submit -->
                <button type="submit" class="btn-login">
                    Войти в систему
                </button>

                <!-- Error message -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-box">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @Html.ValidationMessage("AuthError")
                    </div>
                }

            </form>

            <div class="dots">
                <span></span><span></span><span></span>
            </div>

            <p class="card-footer-note">© @DateTime.Now.Year Счастье есть</p>

        </div>
    </div>

</body>
</html>
